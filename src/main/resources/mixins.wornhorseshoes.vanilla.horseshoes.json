{
  "required": true,
  "package": "wornhorseshoes.mixin",
  "refmap": "mixins.wornhorseshoes.refmap.json",
  "compatibilityLevel": "JAVA_8",
  "target": "@env(DEFAULT)",
  "minVersion": "0.8",
  "mixins": [
    "vanilla.horseshoes.HorseshoesSlotInContainer",
    "vanilla.horseshoes.DispenseHorseshoes",
    "vanilla.horseshoes.NBT_HorseShoes",
    "vanilla.horseshoes.increaseinvsize.AbstractChestHorse_IncreaseInventorySize",
    "vanilla.horseshoes.increaseinvsize.AbstractHorse_IncreaseInventorySize",
    "vanilla.horseshoes.increaseinvsize.Llama_IncreaseInventorySize"
  ],
  "injectors": {
    "maxShiftBy": 10
  },
  "client": [
    "vanilla.horseshoes.DrawHorseshoesSlotInGui"
  ],
  "mixinextras": {
    "minVersion": "0.5.0"
  }
}